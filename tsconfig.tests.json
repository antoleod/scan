{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "outDir": ".test-dist",
    "rootDir": ".",
    "noEmit": false,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "tests/run-tests.ts",
    "src/declarations.d.ts",
    "src/core/barcode.ts",
    "src/core/classify.ts",
    "src/core/extract.ts",
    "src/core/routes.ts",
    "src/core/shoppingDictionary.ts",
    "src/core/shoppingList.ts",
    "src/core/settings.ts",
    "src/types.ts",
    "src/features/airdrop/utils/qr.ts",
    "src/features/airdrop/constants/index.ts",
    "src/features/airdrop/types/index.ts"
  ]
}
