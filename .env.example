# Get these from: Firebase Console -> Project Settings -> General -> Your apps -> Web App -> Config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1
# Realtime Database URL — enables P2P image sync between devices (free tier)
# Firebase Console -> Realtime Database -> Copy the database URL
# Format: https://<project-id>-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_SITE_KEY=
EXPO_PUBLIC_ENABLE_ANALYTICS=false
# Optional flags
EXPO_PUBLIC_ENABLE_UPDATES=false

# Cloud Functions runtime variables / secrets, not EXPO_PUBLIC and not bundled:
# OPENAI_API_KEY=
# OPENAI_MODEL=
# SENDGRID_API_KEY=
# INTEGRATION_EMAIL_FROM=
# SERVICENOW_BASE_URL=
# SERVICENOW_TOKEN=
# SERVICENOW_USER=
# SERVICENOW_PASSWORD=
