rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasOnlyKeys(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    // Admin role check: caller must have a document in /admins/{uid} with role 'admin'.
    // Uses exists() (cheap) for write-gate; get() only where role value matters.
    function callerIsAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // Tester or admin — both can read analytics. Admins can also write.
    function callerIsTesterOrAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function noteTombstoneValid() {
      return hasOnlyKeys([
        'id',
        'deletedAt',
        'uid',
        'groupId',
        'updatedAtServer'
      ])
      && request.resource.data.id is string
      && request.resource.data.deletedAt is number
      && request.resource.data.uid == request.auth.uid;
    }

    function noteCommonValid() {
      return hasOnlyKeys([
        'id',
        'kind',
        'category',
        'text',
        'title',
        'groupId',
        'color',
        'archived',
        'imageBase64',
        'imageMimeType',
        'attachments',
        'imageRtdbPaths',
        'hasLocalImage',
        'hasLocalAttachments',
        'pinned',
        'versions',
        'smartType',
        'smartLabel',
        'workflowStatus',
        'workflowMetadata',
        'isSecret',
        'draft',
        'createdAt',
        'updatedAt',
        'deletedAt',
        'uid',
        'updatedAtServer'
      ])
      && request.resource.data.id is string
      && request.resource.data.kind in ['text', 'image']
      && request.resource.data.category in ['general', 'work', 'health', 'shopping']
      && request.resource.data.text is string
      && request.resource.data.text.size() < 50000
      && request.resource.data.pinned is bool
      && request.resource.data.createdAt is number
      && request.resource.data.updatedAt is number
      && (!('groupId' in request.resource.data) || request.resource.data.groupId is string)
      && (!('color' in request.resource.data) || request.resource.data.color in ['default', 'amber', 'mint', 'sky', 'rose'])
      && (!('archived' in request.resource.data) || request.resource.data.archived is bool)
      && (!('deletedAt' in request.resource.data) || request.resource.data.deletedAt is number)
      && (!('title' in request.resource.data) || (request.resource.data.title is string && request.resource.data.title.size() < 500))
      && (!('attachments' in request.resource.data) || request.resource.data.attachments is list)
      && (!('imageRtdbPaths' in request.resource.data) || request.resource.data.imageRtdbPaths is list)
      && (!('versions' in request.resource.data) || (request.resource.data.versions is list && request.resource.data.versions.size() <= 12))
      && (!('smartType' in request.resource.data) || request.resource.data.smartType is string)
      && (!('smartLabel' in request.resource.data) || request.resource.data.smartLabel is string)
      && (!('workflowStatus' in request.resource.data) || request.resource.data.workflowStatus is string)
      && (!('isSecret' in request.resource.data) || request.resource.data.isSecret is bool)
      && (!('draft' in request.resource.data) || request.resource.data.draft is bool)
      && (!('hasLocalImage' in request.resource.data) || request.resource.data.hasLocalImage is bool)
      && (!('hasLocalAttachments' in request.resource.data) || request.resource.data.hasLocalAttachments is bool);
    }

    function noteValid() {
      return noteTombstoneValid() || (
        noteCommonValid()
        && request.resource.data.uid == request.auth.uid
      );
    }

    function groupNoteValid(groupId) {
      return noteTombstoneValid() || (
        noteCommonValid()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.groupId == groupId
      );
    }

    function templateValid() {
      return hasOnlyKeys([
        'id',
        'name',
        'kind',
        'to',
        'subject',
        'body',
        'location',
        'durationMinutes',
        'createdAt',
        'updatedAt',
        'uid',
        'updatedAtServer'
      ])
      && request.resource.data.id is string
      && request.resource.data.name is string
      && request.resource.data.kind in ['email', 'appointment']
      && request.resource.data.subject is string
      && request.resource.data.body is string
      && request.resource.data.createdAt is number
      && request.resource.data.updatedAt is number
      && request.resource.data.uid == request.auth.uid
      && (!('to' in request.resource.data) || request.resource.data.to is string)
      && (!('location' in request.resource.data) || request.resource.data.location is string)
      && (!('durationMinutes' in request.resource.data) || request.resource.data.durationMinutes is number);
    }

    function scanValid() {
      return request.resource.data.uid == request.auth.uid;
    }

    // analyticsDaily counter documents only ever hold these numeric counter
    // fields (written via increment() from authenticated clients). Validating
    // the key set prevents a signed-in user from stuffing arbitrary fields or
    // overwriting the doc with a non-counter payload.
    function analyticsDailyValid() {
      return hasOnlyKeys([
        'appOpens',
        'loginCount',
        'noteCreatedCount',
        'noteUpdatedCount',
        'noteDeletedCount',
        'scanCount',
        'scanFailedCount',
        'transferCount',
        'transferFailedCount'
      ])
      && (!('appOpens' in request.resource.data) || request.resource.data.appOpens is number)
      && (!('loginCount' in request.resource.data) || request.resource.data.loginCount is number)
      && (!('noteCreatedCount' in request.resource.data) || request.resource.data.noteCreatedCount is number)
      && (!('noteUpdatedCount' in request.resource.data) || request.resource.data.noteUpdatedCount is number)
      && (!('noteDeletedCount' in request.resource.data) || request.resource.data.noteDeletedCount is number)
      && (!('scanCount' in request.resource.data) || request.resource.data.scanCount is number)
      && (!('scanFailedCount' in request.resource.data) || request.resource.data.scanFailedCount is number)
      && (!('transferCount' in request.resource.data) || request.resource.data.transferCount is number)
      && (!('transferFailedCount' in request.resource.data) || request.resource.data.transferFailedCount is number);
    }

    // adminAlerts created by clients during quota events. Validate the shape so
    // a signed-in user cannot spam the admin panel with arbitrary documents.
    function adminAlertValid() {
      return request.resource.data.type is string
        && request.resource.data.type.size() < 64
        && request.resource.data.createdAt is number
        && (!('message' in request.resource.data) || (request.resource.data.message is string && request.resource.data.message.size() < 1000))
        && (!('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid);
    }

    function usernameDocValid() {
      return hasOnlyKeys(['username', 'uid', 'authEmailSource', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.authEmailSource is string;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || callerIsAdmin();

      // Keep the root doc blocked unless the app explicitly starts using it.
      allow create, update, delete: if false;

      match /private/{docId} {
        // Admins may read profile docs for user management (email/username lookup).
        // Writes remain owner-only.
        allow read: if isOwner(uid) || callerIsAdmin();
        allow write: if isOwner(uid);
      }

      match /scans/{scanId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && scanValid();
        allow delete: if isOwner(uid);
      }

      match /notes/{noteId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && noteValid();
        allow delete: if isOwner(uid);
      }

      match /noteTemplates/{templateId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && templateValid();
        allow delete: if isOwner(uid);
      }

      match /clipboard/{entryId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /noteGroups/{groupId} {
      allow read: if signedIn()
        && (resource.data.members.hasAny([request.auth.uid]) || resource.data.ownerUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.members is list
        && request.resource.data.members.size() <= 50
        && request.resource.data.members.hasAny([request.auth.uid])
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string;

      // Only the owner may modify the group document directly. Joining a group
      // must go through the `joinSharedNoteGroupByInvite` Cloud Function, which
      // validates the invite code with Admin SDK privileges (bypassing rules).
      // The previous self-add update path let any signed-in user add themselves
      // to any group whose ID they knew, without ever supplying the code.
      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.name is string
        && request.resource.data.inviteCode is string
        && request.resource.data.members is list
        && request.resource.data.members.size() <= 50;

      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      match /notes/{noteId} {
        function isGroupMember() {
          return signedIn()
            && get(/databases/$(database)/documents/noteGroups/$(groupId)).data.members.hasAny([request.auth.uid]);
        }
        function isGroupOwner() {
          return signedIn()
            && get(/databases/$(database)/documents/noteGroups/$(groupId)).data.ownerUid == request.auth.uid;
        }

        allow read: if isGroupMember();
        // Group members may create their own notes inside a group (uid must
        // match the caller, groupId must match the path, and the payload must
        // pass the same schema validation as personal notes).
        allow create: if isGroupMember() && groupNoteValid(groupId);
        // Updates: only the original author may edit their own note. This
        // prevents members from overwriting each other.
        allow update: if isGroupMember()
          && groupNoteValid(groupId)
          && resource.data.uid == request.auth.uid;
        // Deletes: author or group owner.
        allow delete: if isGroupMember()
          && (resource.data.uid == request.auth.uid || isGroupOwner());
      }
    }

    // `/usernames/{username}` is publicly readable so unauthenticated clients
    // can resolve a username → uid at login time. The doc must therefore
    // contain NO PII: never store the user's recovery email here. The auth
    // email is stored privately under /users/{uid}/private/profile.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn()
                    && usernameDocValid()
                    && request.resource.data.username == username;
      allow update: if signedIn()
                    && resource.data.uid == request.auth.uid
                    && usernameDocValid()
                    && request.resource.data.username == username;
      allow delete: if false;
    }

    match /authAttempts/{attemptId} {
      // Server-side only (Cloud Function rate limiter writes via Admin SDK,
      // which bypasses rules).
      allow read, write: if false;
    }

    // ── Admin role allowlist ─────────────────────────────────────────────────
    // /admins/{uid}: { uid, role: 'admin'|'tester', addedAt, addedBy, email?, displayName? }
    match /admins/{uid} {
      // Any signed-in user may read their OWN record (for role check on login).
      allow get: if isOwner(uid);
      // Admins may list all admin records (for admin management UI).
      allow list: if callerIsAdmin();

      // ── BOOTSTRAP PATH (CLOSED) ───────────────────────────────────────────
      // Client-side self-promotion is DISABLED. The previous rule let any
      // signed-in user create their own /admins/{uid} doc with role 'admin'
      // as long as no record existed yet — meaning the first attacker to
      // reach a fresh deployment could self-promote to admin.
      //
      // The first admin is now provisioned server-side only, via
      // `scripts/bootstrap.js` (Admin SDK / REST with the owner's
      // credentials), which bypasses these rules. Subsequent admins/testers
      // are granted through the `allow update` path below by an existing
      // admin. There is no client create path.
      allow create: if false;

      // Normal path: only existing admins may grant/update roles.
      allow update: if callerIsAdmin()
        && request.resource.data.uid is string
        && request.resource.data.role in ['admin', 'tester']
        && request.resource.data.addedBy is string;
      allow delete: if callerIsAdmin();
    }

    // ── Analytics collections (Phase 2) — stubs, locked until then ──────────
    // analyticsDaily/{yyyyMMdd}     — global daily aggregates
    // userAnalytics/{uid}/daily/{yyyyMMdd} — per-user daily aggregates
    //
    // Normal users can only read their own analytics.
    // Admins/testers can read all analytics.
    // Writes come from the app client (aggregates) or Cloud Functions (server).
    match /analyticsDaily/{dateKey} {
      allow read: if callerIsTesterOrAdmin();
      // Client writes aggregated counters using increment(); only the owning
      // uid can write its own presence mark in the activeUsers subcollection.
      // Payload is restricted to the known numeric counter fields so a
      // signed-in user cannot overwrite the doc with arbitrary data.
      allow update: if signedIn() && analyticsDailyValid();
      allow create: if signedIn() && analyticsDailyValid();
      allow delete: if callerIsAdmin();

      match /activeUsers/{uid} {
        allow read: if callerIsTesterOrAdmin();
        allow write: if isOwner(uid); // each user writes their own presence mark
      }
    }

    match /userAnalytics/{uid} {
      allow read: if isOwner(uid) || callerIsTesterOrAdmin();
      allow write: if false; // client writes go to subcollection below

      match /daily/{dateKey} {
        allow read: if isOwner(uid) || callerIsTesterOrAdmin();
        // Client increments own counters; admin can write any.
        allow create, update: if isOwner(uid) || callerIsAdmin();
        allow delete: if callerIsAdmin();
      }
    }

    // ── User stats (Phase 2) — aggregate totals per user ────────────────────
    // users/{uid}/stats/summary: lifetime totals
    match /users/{uid}/stats/{docId} {
      allow read: if isOwner(uid) || callerIsTesterOrAdmin();
      allow create, update: if isOwner(uid) || callerIsAdmin();
      allow delete: if callerIsAdmin();
    }

    // ── Cloud relay quota (Phase 4) ──────────────────────────────────────────

    // Global relay state — admin-writable; testers/admins can read.
    // Normal users can only read whether the relay is enabled (for UI gates).
    match /cloudRelay/globalState {
      allow get: if signedIn();            // any signed-in user needs to know if relay is on
      allow list: if callerIsTesterOrAdmin();
      allow create, update, delete: if callerIsAdmin();
    }

    // Per-user usage — owner can read their own; admins see all.
    // Writes come from Firestore transactions (via client runTransaction).
    match /cloudRelay/userUsage/{uid}/{periodKey} {
      allow read: if isOwner(uid) || callerIsTesterOrAdmin();
      allow write: if isOwner(uid) || callerIsAdmin();
    }

    // Transfer sessions — owner can read their own session.
    match /transferSessions/{sessionId} {
      allow read: if signedIn()
        && (resource.data.ownerUid == request.auth.uid
            || resource.data.receiverUid == request.auth.uid
            || callerIsAdmin());
      // Sessions are created by the client via runTransaction in the preflight.
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'reserved'
        && request.resource.data.sizeBytes is number
        && request.resource.data.filename is string;
      allow update: if signedIn()
        && (resource.data.ownerUid == request.auth.uid
            || resource.data.receiverUid == request.auth.uid
            || callerIsAdmin());
      allow delete: if callerIsAdmin();
    }

    // Admin alerts — only admins/testers can read; writes come from app via service.
    match /adminAlerts/{alertId} {
      allow read: if callerIsTesterOrAdmin();
      allow create: if signedIn() && adminAlertValid();  // service creates during quota events
      allow update: if callerIsTesterOrAdmin(); // mark read/resolved
      allow delete: if callerIsAdmin();
    }

    // ── userIndex (lightweight user registry written by analytics) ──────────
    // Contains only: { uid, platform, appVersion, lastSeenAt } — NO PII.
    match /userIndex/{uid} {
      // Owner writes their own entry; admins and testers can list/read all.
      allow read: if callerIsTesterOrAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if callerIsAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
